---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BrandLogo from '../components/BrandLogo.astro';
import EducationCards from '../components/EducationCards.astro';
import MediaLightbox from '../components/MediaLightbox.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type ExperienceEntry = CollectionEntry<'experience'>;

const allExperience = await getCollection('experience');
const sortedExperience = allExperience.sort(
  (a: ExperienceEntry, b: ExperienceEntry) => a.data.order - b.data.order
);
const experience = await Promise.all(
  sortedExperience.map(async (exp: ExperienceEntry) => ({
    slug: exp.slug,
    data: exp.data,
    Content: (await exp.render()).Content,
  }))
);

const summaryStats = [
  { value: '4+', label: 'Years across AI, platform, and full-stack systems' },
  { value: '14%', label: 'Engagement lift from Evidenza ad signals' },
  { value: '18%', label: 'Catalog coverage lift from closed-loop alt text' },
  { value: '16%', label: 'Ticket deflection from internal RAG assistant' },
];

const coreDomains = [
  'Production AI / ML',
  'Accessibility Infrastructure',
  'Platform Engineering',
  'Observability',
  'LLM Tooling',
  'Data Pipelines',
];

const highlightCards = [
  {
    title: 'Platform reliability',
    detail: 'Owned on-call reliability for customer-facing CVS Health platform systems including Digital Blocks 2.0 and Previews.',
  },
  {
    title: 'Accessibility systems',
    detail: 'Built and contributed to accessibility automation, reporting, and alt-text systems across Aetna and CVS Health.',
  },
  {
    title: 'Applied AI',
    detail: 'Built RAG assistants, VLM/LLM-judge workflows, and agentic orchestration systems with measured business outcomes.',
  },
];

const roleSignals: Record<string, { highlight: string; domains: string[] }> = {
  'evidenza': {
    highlight: 'Built LLM-as-judge persona generation and multimodal ad-scoring pipelines, reaching 80% trait coverage and driving a 14% engagement lift in A/B testing.',
    domains: ['LLM-as-Judge', 'MCP', 'FastAPI'],
  },
  'cvs-health': {
    highlight: 'Built closed-loop alt-text and RAG systems, raised catalog coverage by 18%, deflected 16% of tickets, and reduced downtime by 12%.',
    domains: ['RAG', 'VLMs', 'GCP', 'OpenTelemetry'],
  },
  'cvs-health-digital-development': {
    highlight: 'Built Node.js internal developer tooling, adopted by multiple CVS engineering teams, and cut manual upkeep by 75%.',
    domains: ['Node.js', 'MongoDB', 'Grafana', 'Terraform'],
  },
  'aetna': {
    highlight: 'Built Node.js and MongoDB-backed automation systems for accessibility operations, migration workflows, and platform health checks.',
    domains: ['Node.js', 'MongoDB', 'Automation'],
  },
};
---

<Layout title="Experience — Dhairya Mishra" description="Professional experience spanning AI engineering, full-stack development, and ML research at CVS Health, Aetna, and Evidenza.">
  <Navigation />

  <main id="main-content" class="py-20 md:py-28">
    <div class="section-container">
      <div class="mb-16 text-center reveal">
        <p class="mb-4 font-mono text-sm uppercase tracking-widest text-neon-rose">Career</p>
        <h1 class="mb-4 text-4xl font-heading font-bold md:text-5xl">
          Experience <span class="text-gradient-rose">Timeline</span>
        </h1>
        <p class="mx-auto max-w-2xl text-muted">
          4+ years across production AI/ML systems, accessibility infrastructure, platform engineering, and research-adjacent experimentation.
        </p>
      </div>

      <section class="mb-12 grid gap-6 lg:grid-cols-[minmax(0,1.5fr)_minmax(280px,1fr)]">
        <div class="card-neon reveal">
          <p class="text-[10px] font-heading font-semibold uppercase tracking-[0.16em] text-neon-rose">Career summary</p>
          <h2 class="mt-3 text-2xl font-heading font-semibold text-text-bright">This page is optimized for evaluating scope, ownership, and operating range.</h2>
          <p class="mt-4 text-sm leading-relaxed text-muted">
            The strongest signal across these roles is consistent ownership of systems that combine software engineering discipline with operational, accessibility, and ML concerns. The work ranges from customer-facing reliability and internal developer tooling to RAG systems, observability, and multimodal LLM evaluation.
          </p>
          <div class="mt-5 flex flex-wrap gap-2">
            {coreDomains.map((domain) => (
              <span class="rounded-full border border-black/5 bg-base px-2.5 py-1 text-xs text-muted-light">{domain}</span>
            ))}
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
          {summaryStats.map((item, index) => (
            <div class={`reveal reveal-delay-${(index % 4) + 1} rounded-2xl border border-black/5 bg-surface p-5 shadow-neon-sm`}>
              <p class="text-3xl font-heading font-bold text-gradient-rose">{item.value}</p>
              <p class="mt-2 text-sm leading-relaxed text-muted">{item.label}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-16 grid gap-4 md:grid-cols-3">
        {highlightCards.map((card, index) => (
          <div class={`reveal reveal-delay-${(index % 3) + 1} card-neon`}>
            <p class="text-sm font-heading font-semibold text-text-bright">{card.title}</p>
            <p class="mt-2 text-sm leading-relaxed text-muted">{card.detail}</p>
          </div>
        ))}
      </section>

      <div class="relative mx-auto mb-24 max-w-4xl">
        <div class="absolute bottom-0 left-4 top-0 w-px bg-gradient-to-b from-neon-rose/40 via-neon-violet/30 to-transparent md:left-8"></div>

        {experience.map((exp, i) => (
          <div class={`reveal reveal-delay-${i + 1} relative pb-12 pl-12 last:pb-0 md:pl-20`}>
            <div class="absolute left-[11px] top-1 h-3 w-3 rounded-full border-2 border-base bg-neon-rose shadow-neon-sm md:left-[27px]"></div>

            <div class="card-neon group">
              <div class="mb-3 flex items-start gap-3">
                {exp.data.brand && (
                  <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg border border-black/10 bg-base">
                    <BrandLogo brand={exp.data.brand} size="sm" />
                  </div>
                )}
                <div class="flex-1">
                  <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                    <div>
                      <h2 class="text-lg font-heading font-semibold text-text-bright">{exp.data.role}</h2>
                      <p class="text-sm text-neon-rose/70">{exp.data.company} &middot; {exp.data.location}</p>
                    </div>
                    <span class="text-xs font-mono text-muted">{exp.data.startDate} — {exp.data.endDate}</span>
                  </div>
                </div>
              </div>

              {roleSignals[exp.slug] && (
                <div class="mb-4 rounded-xl border border-black/5 bg-base px-4 py-4">
                  <p class="text-[10px] font-heading font-semibold uppercase tracking-[0.16em] text-neon-rose">Top impact</p>
                  <p class="mt-2 text-sm leading-relaxed text-text">{roleSignals[exp.slug].highlight}</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {roleSignals[exp.slug].domains.map((domain) => (
                      <span class="rounded-full border border-black/5 bg-surface px-2.5 py-1 text-xs text-muted-light">{domain}</span>
                    ))}
                  </div>
                </div>
              )}

              <div class="prose-neon prose-neon-sm mt-3">
                <exp.Content />
              </div>
            </div>
          </div>
        ))}
      </div>

      <MediaLightbox />

      <div class="divider-neon-animated mb-20"></div>

      <div class="mb-14 text-center reveal">
        <h2 class="text-3xl font-heading font-bold md:text-4xl">
          Academic <span class="text-gradient-rose">Background</span>
        </h2>
      </div>
      <EducationCards />
    </div>
  </main>

  <Footer />
</Layout>
