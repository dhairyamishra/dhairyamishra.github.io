---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BrandLogo from '../components/BrandLogo.astro';
import EducationCards from '../components/EducationCards.astro';
import MediaLightbox from '../components/MediaLightbox.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type ExperienceEntry = CollectionEntry<'experience'>;

const allExperience = await getCollection('experience');
const sortedExperience = allExperience.sort(
  (a: ExperienceEntry, b: ExperienceEntry) => a.data.order - b.data.order
);
const experience = await Promise.all(
  sortedExperience.map(async (exp: ExperienceEntry) => ({
    slug: exp.slug,
    data: exp.data,
    Content: (await exp.render()).Content,
  }))
);
---

<Layout title="Experience — Dhairya Mishra" description="Professional experience spanning AI engineering, full-stack development, and ML research at CVS Health, Aetna, and Evidenza.">
  <Navigation />

  <main id="main-content" class="py-20 md:py-28">
    <div class="section-container">

      <!-- Page Header -->
      <div class="reveal text-center mb-16">
        <p class="text-neon-rose font-mono text-sm tracking-widest uppercase mb-4">Career</p>
        <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">
          Experience <span class="text-gradient-rose">Timeline</span>
        </h1>
        <p class="text-muted max-w-xl mx-auto">
          5+ years building production AI/ML systems, full-stack platforms, and accessibility infrastructure at scale.
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative max-w-3xl mx-auto mb-24">
        <!-- Vertical thread line -->
        <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-neon-rose/40 via-neon-violet/30 to-transparent"></div>

        {experience.map((exp, i) => (
          <div class={`reveal reveal-delay-${i + 1} relative pl-12 md:pl-20 pb-12 last:pb-0`}>
            <div class="absolute left-[11px] md:left-[27px] top-1 w-3 h-3 rounded-full bg-neon-rose shadow-neon-sm border-2 border-base"></div>

            <div class="card-neon group">
              <div class="flex items-start gap-3 mb-2">
                {exp.data.brand && (
                  <div class="w-9 h-9 rounded-lg bg-base border border-black/10 flex items-center justify-center flex-shrink-0">
                    <BrandLogo brand={exp.data.brand} size="sm" />
                  </div>
                )}
                <div class="flex-1">
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
                    <h2 class="text-lg font-heading font-semibold text-text-bright">{exp.data.role}</h2>
                    <span class="text-xs text-muted font-mono">{exp.data.startDate} — {exp.data.endDate}</span>
                  </div>
                  <p class="text-sm text-neon-rose/70">{exp.data.company} &middot; {exp.data.location}</p>
                </div>
              </div>
              <div class="prose-neon prose-neon-sm mt-3">
                <exp.Content />
              </div>
            </div>
          </div>
        ))}
      </div>

      <MediaLightbox />

      <div class="divider-neon-animated mb-20"></div>

      <!-- Education -->
      <div class="reveal text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
          Academic <span class="text-gradient-rose">Background</span>
        </h2>
      </div>
      <EducationCards />

    </div>
  </main>

  <Footer />
</Layout>
