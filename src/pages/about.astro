---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BrandLogo from '../components/BrandLogo.astro';
import EducationCards from '../components/EducationCards.astro';
import { publications } from '../data/publications';
import profileImg from '../assets/profile.jpg';

---

<Layout title="About — Dhairya Mishra" description="Engineering philosophy, research interests, and the operating principles behind my work." ogType="profile">
  <Navigation />
  
  <main id="main-content" class="py-20 md:py-28">
    <section class="section-container relative mb-16">
      <div class="absolute top-0 right-0 -z-10 h-64 w-64 rounded-full bg-neon-rose/5 blur-3xl"></div>
      
      <div class="max-w-4xl flex flex-col md:flex-row md:items-center md:gap-16">
        <div class="mb-10 flex-shrink-0 md:order-2 md:mb-0">
          <Image
            src={profileImg}
            alt="Dhairya Mishra"
            width={576}
            height={576}
            loading="eager"
            class="mx-auto h-56 w-56 rounded-xl border-2 border-neon-rose/20 object-cover shadow-[0_20px_48px_rgba(36,26,20,0.12)] transition-transform duration-300 hover:-translate-y-2 hover:shadow-[0_24px_56px_rgba(36,26,20,0.16)] md:h-72 md:w-72"
          />
        </div>
        <div class="flex-1">
          <p class="mb-4 font-mono text-sm uppercase tracking-widest text-neon-rose animate-fade-in">About</p>
          <h1 class="mb-6 text-4xl font-heading font-bold leading-tight md:text-5xl">
            I care about systems that are technically ambitious, operationally credible, and useful under real-world constraints.
          </h1>
          <div class="space-y-4 font-body text-base leading-relaxed text-muted-light md:text-lg">
            <p>
              I am a software engineer and ML researcher working at the intersection of distributed systems, applied AI, and developer infrastructure. The common thread in my work is building systems that need to be both technically strong and operationally defensible.
            </p>
            <p>
              Over the last 5+ years, I have built pipelines and platforms used at enterprise scale, including customer-facing reliability work, accessibility infrastructure, RAG tooling, and research systems. I value <strong>reliability, observability, and clear evidence of impact</strong> more than novelty for its own sake.
            </p>
            <p>
              My strongest work tends to sit in the messy middle: where product needs, infrastructure constraints, and model behavior all have to be handled at once without hand-waving.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <section class="section-container py-20">
      <div class="mx-auto max-w-4xl">
        <div class="reveal mb-12 text-center">
          <h2 class="mb-4 text-3xl font-heading font-bold md:text-4xl">
            Engineering <span class="text-gradient-rose">Philosophy</span>
          </h2>
          <p class="text-lg text-muted">Principles that shape how I design, ship, and evaluate systems.</p>
        </div>
        
        <div class="grid gap-8 md:grid-cols-2">
          <div class="card-neon reveal reveal-delay-1">
            <h3 class="mb-3 flex items-center gap-3 text-xl font-heading font-bold text-text-bright">
              <span class="flex h-8 w-8 items-center justify-center rounded-full border border-neon-rose/20 bg-neon-rose/10 font-mono text-sm text-neon-rose">01</span>
              User impact is an engineering metric
            </h3>
            <p class="leading-relaxed text-muted">
              Product quality is the final test of technical work. Latency, failure modes, confusing outputs, and inaccessible interfaces are engineering problems, not downstream concerns.
            </p>
          </div>
          
          <div class="card-neon reveal reveal-delay-2">
            <h3 class="mb-3 flex items-center gap-3 text-xl font-heading font-bold text-text-bright">
              <span class="flex h-8 w-8 items-center justify-center rounded-full border border-neon-gold/20 bg-neon-gold/10 font-mono text-sm text-neon-gold">02</span>
              Rigor beats hype
            </h3>
            <p class="leading-relaxed text-muted">
              I like ambitious systems, but I do not confuse ambition with rigor. I prefer architectures that can be reasoned about, tested, observed, and defended in front of users and teammates.
            </p>
          </div>
          
          <div class="card-neon reveal reveal-delay-3">
            <h3 class="mb-3 flex items-center gap-3 text-xl font-heading font-bold text-text-bright">
              <span class="flex h-8 w-8 items-center justify-center rounded-full border border-neon-violet/20 bg-neon-violet/10 font-mono text-sm text-neon-violet">03</span>
              Observability is part of the product
            </h3>
            <p class="leading-relaxed text-muted">
              If a system cannot be inspected, it cannot be trusted. I treat telemetry, structured logs, and failure visibility as part of the product surface.
            </p>
          </div>
          
          <div class="card-neon reveal reveal-delay-4">
            <h3 class="mb-3 flex items-center gap-3 text-xl font-heading font-bold text-text-bright">
              <span class="flex h-8 w-8 items-center justify-center rounded-full border border-neon-rose/20 bg-neon-rose/10 font-mono text-sm text-neon-rose">04</span>
              Curiosity needs discipline
            </h3>
            <p class="leading-relaxed text-muted">
              I try to keep a researcher's curiosity without losing an engineer's discipline. New ideas matter, but only when they survive contact with data, implementation details, and edge cases.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <section class="section-container py-20">
      <div class="reveal mb-14 text-center">
        <h2 class="mb-4 text-3xl font-heading font-bold md:text-4xl">
          Publications & <span class="text-gradient-rose">Research</span>
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-muted">
          My research interests are strongest where systems and learning interact: <strong>multi-agent reinforcement learning</strong>, <strong>video world models</strong>, and <strong>evaluation-heavy ML infrastructure</strong>.
        </p>
      </div>
      
      <div class="mx-auto grid max-w-3xl gap-6">
        {publications.map((pub, i) => (
          <div class={`reveal reveal-delay-${i + 1} card-neon group relative overflow-hidden`}>
            <div class="absolute inset-0 bg-gradient-to-r from-neon-violet/5 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>

            <div class="relative z-10">
              <div class="mb-3 flex items-start gap-4">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg border border-neon-violet/20 bg-neon-violet/10 shadow-inner">
                  <BrandLogo brand={pub.venueBrand} size="sm" />
                </div>
                <div class="flex-1">
                  <h3 class="text-lg font-heading font-semibold leading-tight text-text-bright">{pub.title}</h3>
                  <p class="mt-1 text-sm font-medium text-neon-rose/80">{pub.venue}</p>
                </div>
              </div>

              <div class="mt-4 pl-16">
                <div class="mb-3 flex flex-wrap items-center gap-2">
                  <span class="rounded-full border border-black/10 bg-base px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-muted">{pub.role}</span>
                  <span class="text-xs text-black/10">|</span>
                  <span class="text-sm text-muted">{pub.institution}</span>
                  <span class="text-xs text-black/10">|</span>
                  <span class="text-sm font-mono text-muted">{pub.date}</span>
                  {pub.url && (
                    <>
                      <span class="text-xs text-black/10">|</span>
                      <a
                        href={pub.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="link-neon text-sm font-mono"
                      >
                        arXiv
                      </a>
                    </>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <section class="section-container py-20 md:pb-28">
      <div class="reveal mb-14 text-center">
        <h2 class="mb-4 text-3xl font-heading font-bold md:text-4xl">
          Academic <span class="text-gradient-rose">Background</span>
        </h2>
      </div>
      
      <EducationCards />
    </section>
  </main>

  <Footer />
</Layout>
