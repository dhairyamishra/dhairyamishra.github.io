---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BrandLogo from '../components/BrandLogo.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import profileImg from '../assets/profile.jpg';

type ProjectEntry = CollectionEntry<'projects'>;

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p: ProjectEntry) => p.data.featured)
  .sort((a: ProjectEntry, b: ProjectEntry) => b.data.date.localeCompare(a.data.date))
  .slice(0, 4);

const proofPoints = [
  { value: '18%', label: 'Alt-text catalog coverage lift', detail: 'CVS closed-loop VLM + LLM-judge system' },
  { value: '16%', label: 'Ticket deflection', detail: 'CVS self-service RAG assistant' },
  { value: '12.64M', label: 'Synchronized multiplayer frames', detail: 'Solaris world-model research dataset' },
  { value: '96.57%', label: 'DistilBERT accuracy', detail: 'Cloud NLP content moderation API' },
];

const quickPaths = [
  { label: 'Best for recruiters', href: '/experience', description: 'Timeline, ownership, and outcomes' },
  { label: 'Best for engineers', href: '#technical-wins', description: 'Architecture and systems proof' },
  { label: 'Best for research', href: '/projects/solaris', description: 'World models, evaluation, and publication work' },
];

const technicalWins = [
  {
    eyebrow: 'Production Systems',
    title: 'Built AI-supported internal systems at CVS Health',
    metric: '16% ticket deflection',
    summary:
      'Built a self-service RAG assistant over ticket history and internal docs, cut resolution time by 20%, and owned reliability for customer-facing platform systems.',
    links: [
      { label: 'Experience', href: '/experience' },
      { label: 'RAG Assistant', href: '/projects/cvs-rag-assistant' },
    ],
  },
  {
    eyebrow: 'Accessibility Infrastructure',
    title: 'Turned accessibility from manual review into automated enforcement',
    metric: '18% coverage lift',
    summary:
      'Built a closed-loop alt-text pipeline using a Hugging Face VLM and LLM judge, and contributed to ensemble accessibility tooling through Testaro.',
    links: [
      { label: 'Testaro', href: '/projects/testaro' },
      { label: 'Experience', href: '/experience' },
    ],
  },
  {
    eyebrow: 'Research + Applied ML',
    title: 'Built systems spanning world models, LLM pipelines, and multimodal tooling',
    metric: 'NeurIPS + production',
    summary:
      'Contributed to Solaris multiplayer world-model research, built a live graph-based research agent, and trained/evaluated applied ML systems across NLP and medical imaging.',
    links: [
      { label: 'Solaris', href: '/projects/solaris' },
      { label: 'PICO-LLM', href: '/projects/pico-llm' },
    ],
  },
];

const capabilities = [
  {
    title: 'Production AI / ML Systems',
    evidence:
      'Built RAG assistants, alt-text automation, graph-based research tooling, and model-backed internal platforms with deployment and operational ownership.',
    tools: ['Hugging Face', 'RAG', 'FastAPI', 'Terraform', 'ArgoCD'],
  },
  {
    title: 'Distributed Platform Engineering',
    evidence:
      'Built internal developer tooling, observability pipelines, storage, databases, and cloud deployment workflows for enterprise and production-facing systems.',
    tools: ['GCP', 'Postgres', 'MongoDB', 'OpenTelemetry', 'Grafana'],
  },
  {
    title: 'Evaluation and Research Discipline',
    evidence:
      'Designed reproducible experiment pipelines, multi-agent evaluation frameworks, and cross-run analysis for LLM and world-model research.',
    tools: ['PyTorch', 'JAX', 'wandb', 'VLM-as-Judge', 'Playwright'],
  },
];

const affiliations = [
  { brand: 'nyu', label: 'NYU Courant' },
  { brand: 'trine', label: 'Trine University' },
  { brand: 'cvs', label: 'CVS Health' },
  { brand: 'aetna', label: 'Aetna' },
  { brand: 'evidenza', label: 'Evidenza' },
  { brand: 'acm', label: 'ACM' },
  { brand: 'neurips', label: 'NeurIPS' },
  { brand: 'arxiv', label: 'arXiv' },
];
---

<Layout title="Dhairya Mishra — Software Engineer & ML Researcher" ogType="profile">
  <Navigation />

  <main id="main-content">
    <section class="relative overflow-hidden py-20 md:py-28">
      <div class="absolute inset-0 grid-bg opacity-40"></div>
      <div class="absolute top-12 left-0 h-64 w-64 rounded-full bg-neon-gold/5 blur-3xl"></div>
      <div class="absolute right-0 top-32 h-72 w-72 rounded-full bg-neon-rose/5 blur-3xl"></div>

      <div class="section-container relative z-10">
        <div class="grid items-center gap-12 lg:grid-cols-[minmax(0,1.4fr)_minmax(280px,420px)]">
          <div class="reveal">
            <p class="mb-5 font-mono text-sm uppercase tracking-[0.24em] text-neon-rose">
              Software Engineer · ML Researcher
            </p>
            <h1 class="max-w-4xl text-5xl font-heading font-bold leading-[0.96] text-text-bright sm:text-6xl lg:text-7xl">
              I build production AI systems, developer infrastructure, and research-grade ML pipelines that hold up under real constraints.
            </h1>
            <p class="mt-6 max-w-3xl text-lg leading-relaxed text-muted-light md:text-xl">
              My work spans customer-facing platform reliability, accessibility automation, RAG systems, and world-model research — from internal enterprise tooling to NeurIPS-scale experiments.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a href="/projects" class="btn-neon-fill">
                Review flagship work
                <svg class="ml-2 inline-block h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
              </a>
              <a href="/experience" class="btn-neon">
                Review experience
                <svg class="ml-2 inline-block h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>

            <div class="mt-10 grid gap-3 md:grid-cols-3">
              {quickPaths.map((path, index) => (
                <a
                  href={path.href}
                  class={`reveal reveal-delay-${index + 1} card-neon-interactive p-4`}
                >
                  <p class="text-xs font-heading font-semibold uppercase tracking-[0.16em] text-neon-rose">{path.label}</p>
                  <p class="mt-2 text-sm leading-relaxed text-muted">{path.description}</p>
                </a>
              ))}
            </div>
          </div>

          <div class="reveal reveal-delay-2">
            <div class="flex flex-col items-start gap-6">
              <Image
                src={profileImg}
                alt="Dhairya Mishra"
                width={448}
                height={448}
                loading="eager"
                class="h-44 w-44 rounded-3xl border-2 border-neon-rose/20 object-cover shadow-[0_24px_56px_rgba(36,26,20,0.14)] md:h-56 md:w-56"
              />

              <div class="card-neon w-full p-5 md:p-6">
                <div class="flex-1">
                  <p class="text-xs font-mono uppercase tracking-[0.16em] text-muted">Current focus</p>
                  <h2 class="mt-2 text-xl font-heading font-semibold text-text-bright">Applied ML with production judgment</h2>
                  <p class="mt-3 text-sm leading-relaxed text-muted">
                    Engineering systems where model quality, reliability, observability, and operator experience all matter at the same time.
                  </p>
                </div>

                <div class="mt-6 space-y-3 border-t border-black/5 pt-5">
                  <div class="grid gap-1 sm:grid-cols-[140px_minmax(0,1fr)] sm:gap-4">
                    <span class="text-sm text-muted">Primary domains</span>
                    <span class="text-sm font-medium text-text">LLMs · accessibility · platform infra</span>
                  </div>
                  <div class="grid gap-1 sm:grid-cols-[140px_minmax(0,1fr)] sm:gap-4">
                    <span class="text-sm text-muted">Recent signal</span>
                    <span class="text-sm font-medium text-text">NeurIPS 2026 submission + live shipped systems</span>
                  </div>
                  <div class="grid gap-1 sm:grid-cols-[140px_minmax(0,1fr)] sm:gap-4">
                    <span class="text-sm text-muted">Operating style</span>
                    <span class="text-sm font-medium text-text">Own architecture, delivery, and outcomes</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-black/5 py-10 md:py-12">
      <div class="section-container">
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {proofPoints.map((item, index) => (
            <div class={`reveal reveal-delay-${(index % 4) + 1} rounded-2xl border border-black/5 bg-surface p-5 shadow-neon-sm`}>
              <p class="text-3xl font-heading font-bold text-gradient-rose">{item.value}</p>
              <p class="mt-2 text-sm font-medium text-text">{item.label}</p>
              <p class="mt-1 text-sm leading-relaxed text-muted">{item.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="technical-wins" class="py-20 md:py-24">
      <div class="section-container">
        <div class="reveal mb-12 max-w-3xl">
          <p class="text-sm font-mono uppercase tracking-[0.2em] text-neon-rose">Selected technical wins</p>
          <h2 class="mt-4 text-3xl font-heading font-bold text-text-bright md:text-4xl">
            The strongest signal is shipped work under real constraints.
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-muted">
            These are representative examples of ownership across production systems, accessibility infrastructure, and research-intensive ML work.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {technicalWins.map((win, index) => (
            <div class={`reveal reveal-delay-${(index % 3) + 1} card-neon flex flex-col`}>
              <p class="text-xs font-heading font-semibold uppercase tracking-[0.16em] text-neon-rose">{win.eyebrow}</p>
              <h3 class="mt-3 text-2xl font-heading font-semibold text-text-bright">{win.title}</h3>
              <p class="mt-3 text-sm font-medium uppercase tracking-[0.12em] text-neon-gold">{win.metric}</p>
              <p class="mt-4 flex-grow text-sm leading-relaxed text-muted">{win.summary}</p>
              <div class="mt-5 flex flex-wrap gap-3">
                {win.links.map((link) => (
                  <a href={link.href} class="link-neon text-sm font-medium">
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 md:py-24">
      <div class="section-container">
        <div class="reveal mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div class="max-w-2xl">
            <p class="text-sm font-mono uppercase tracking-[0.2em] text-neon-rose">Flagship work</p>
            <h2 class="mt-4 text-3xl font-heading font-bold text-text-bright md:text-4xl">
              Projects that best represent technical depth and execution range.
            </h2>
          </div>
          <p class="max-w-xl text-sm leading-relaxed text-muted">
            A mix of shipped enterprise systems, agentic product work, and research pipelines. Each project includes architecture, decisions, and results.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {featuredProjects.map((project: ProjectEntry, index: number) => (
            <ProjectCard
              project={project}
              maxTags={4}
              showReadMore
              revealClass={`reveal reveal-delay-${(index % 4) + 1}`}
            />
          ))}
        </div>

        <div class="reveal mt-10">
          <a href="/projects" class="btn-neon text-sm">
            View all projects
            <svg class="ml-2 inline-block h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <section class="py-20 md:py-24">
      <div class="section-container">
        <div class="reveal mb-12 max-w-3xl">
          <p class="text-sm font-mono uppercase tracking-[0.2em] text-neon-rose">Capabilities</p>
          <h2 class="mt-4 text-3xl font-heading font-bold text-text-bright md:text-4xl">
            Broad tool coverage matters less than where the tools have already been proven.
          </h2>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {capabilities.map((capability, index) => (
            <div class={`reveal reveal-delay-${(index % 3) + 1} card-neon`}>
              <h3 class="text-xl font-heading font-semibold text-text-bright">{capability.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-muted">{capability.evidence}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {capability.tools.map((tool) => (
                  <span class="rounded-full border border-black/5 bg-base px-2.5 py-1 text-xs text-muted-light">{tool}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y border-black/5 py-10">
      <div class="section-container">
        <p class="reveal mb-6 text-center text-[10px] uppercase tracking-[0.2em] text-muted">Affiliated with</p>
        <div class="brand-strip">
          {affiliations.map((item, index) => (
            <div class={`brand-strip-item reveal reveal-delay-${(index % 5) + 1}`}>
              <BrandLogo brand={item.brand} size="md" />
              <span class="text-[10px] text-muted/70">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 md:py-24">
      <div class="section-container text-center">
        <div class="reveal card-neon mx-auto max-w-3xl py-12 px-8">
          <p class="text-sm font-mono uppercase tracking-[0.2em] text-neon-rose">Next step</p>
          <h2 class="mt-4 text-3xl font-heading font-bold text-text-bright">
            If you need someone who can own both the model and the system around it, start here.
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-muted">
            I am most useful on teams building production AI products, internal engineering platforms, accessibility infrastructure, and research systems that need to survive contact with real users.
          </p>
          <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
            <a href="/contact" class="btn-neon-fill">Start a conversation</a>
            <a href="https://github.com/dhairyamishra" target="_blank" rel="noopener noreferrer" class="btn-neon">
              <Icon name="simple-icons:github" class="mr-2 inline-block h-4 w-4" aria-hidden="true" />
              Review GitHub
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
