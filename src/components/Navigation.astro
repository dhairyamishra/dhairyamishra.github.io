---
import SocialLinks from './SocialLinks.astro';

const navItems = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Projects', href: '/projects' },
  { name: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-base/80 backdrop-blur-xl border-b border-white/5" id="main-nav">
  <div class="section-container">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="text-xl font-heading font-bold text-gradient-rose hover:opacity-80 transition-opacity">
        DM<span class="text-neon-rose">.</span>
      </a>
      
      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`relative py-1 text-sm font-medium tracking-wide transition-colors duration-200 ${
              currentPath === item.href
                ? 'text-neon-rose'
                : 'text-muted-light hover:text-text'
            }`}
          >
            {item.name}
            {currentPath === item.href && (
              <span class="absolute -bottom-[1px] left-0 w-full h-px bg-neon-rose shadow-neon-sm" />
            )}
          </a>
        ))}
      </div>

      <!-- Social Links (desktop) -->
      <div class="hidden md:block">
        <SocialLinks variant="icon-only" />
      </div>
      
      <!-- Mobile Menu Button -->
      <button
        class="md:hidden text-muted-light hover:text-neon-rose transition-colors p-2"
        id="mobile-menu-btn"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6 hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-6 h-6 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="md:hidden hidden" id="mobile-menu">
    <div class="px-4 py-6 space-y-1 bg-base/95 backdrop-blur-xl border-t border-white/5">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`block px-4 py-3 rounded-lg text-sm font-medium tracking-wide transition-all duration-200 ${
            currentPath === item.href
              ? 'text-neon-rose bg-neon-rose/5'
              : 'text-muted-light hover:text-text hover:bg-white/5'
          }`}
        >
          {item.name}
        </a>
      ))}
      <div class="divider-neon my-4"></div>
      <div class="px-4 py-2">
        <SocialLinks variant="icon-only" containerClass="flex items-center space-x-6" />
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = btn?.querySelector('.hamburger-icon');
  const closeIcon = btn?.querySelector('.close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('astro:after-swap', () => {
    menu?.classList.add('hidden');
    hamburger?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
  });
</script>
