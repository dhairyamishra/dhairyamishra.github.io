---
interface Props {
  number: string;
  eyebrow: string;
  title: string;
  description: string;
  ownership: string;
  metric: string;
  metricLabel: string;
  image: string;
  imageAlt: string;
  imageWidth: number;
  imageHeight: number;
  imagePosition?: string;
  href: string;
  accent?: 'rose' | 'gold';
}

const {
  number,
  eyebrow,
  title,
  description,
  ownership,
  metric,
  metricLabel,
  image,
  imageAlt,
  imageWidth,
  imageHeight,
  imagePosition = 'center',
  href,
  accent = 'rose',
} = Astro.props;

const accentClasses =
  accent === 'gold' ? 'bg-neon-gold text-white' : 'bg-neon-rose text-white';
---

<a
  href={href}
  class="group flex h-full flex-col overflow-hidden rounded-2xl border border-black/10 bg-surface shadow-neon-sm transition-all duration-300 hover:-translate-y-1 hover:border-neon-rose/25 hover:shadow-neon-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neon-rose focus-visible:ring-offset-4 focus-visible:ring-offset-base"
  aria-label={`View the ${title} case study`}
>
  <div class="relative aspect-[16/9] overflow-hidden border-b border-black/10 bg-text-bright">
    <img
      src={image}
      alt={imageAlt}
      width={imageWidth}
      height={imageHeight}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.025]"
      style={`object-position: ${imagePosition}`}
    />
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/35 via-transparent to-black/5"></div>
    <span class={`absolute left-4 top-4 rounded-full px-3 py-1 text-[10px] font-heading font-semibold uppercase tracking-[0.16em] shadow-sm ${accentClasses}`}>
      {eyebrow}
    </span>
    <span class="absolute right-4 top-4 rounded-full border border-white/20 bg-black/45 px-2.5 py-1 font-mono text-[10px] text-white backdrop-blur-sm">
      {number}
    </span>
  </div>

  <div class="flex flex-1 flex-col p-5 sm:p-6">
    <div class="flex items-start justify-between gap-4 border-b border-black/10 pb-4">
      <p class="max-w-[12rem] text-[10px] font-heading font-semibold uppercase leading-relaxed tracking-[0.15em] text-muted">
        {ownership}
      </p>
      <div class="flex-none text-right">
        <p class="text-xl font-heading font-bold tracking-[-0.03em] text-neon-rose">{metric}</p>
        <p class="mt-0.5 text-[10px] text-muted">{metricLabel}</p>
      </div>
    </div>

    <h3 class="mt-5 text-xl font-heading font-semibold leading-tight text-text-bright transition-colors group-hover:text-neon-rose">
      {title}
    </h3>
    <p class="mt-3 text-sm leading-relaxed text-muted">{description}</p>

    <span class="mt-6 inline-flex items-center text-sm font-medium text-neon-rose">
      View case study
      <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </span>
  </div>
</a>
