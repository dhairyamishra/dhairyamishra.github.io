<dialog id="media-lightbox" class="media-lightbox" aria-label="Media viewer">
  <div class="media-lightbox__backdrop"></div>
  <div class="media-lightbox__content">
    <button type="button" class="media-lightbox__close" aria-label="Close viewer">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
    </button>

    <button type="button" class="media-lightbox__nav media-lightbox__nav--prev" aria-label="Previous image">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
    </button>

    <img class="media-lightbox__img" src="" alt="" />

    <button type="button" class="media-lightbox__nav media-lightbox__nav--next" aria-label="Next image">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
    </button>

    <p class="media-lightbox__caption"></p>
    <p class="media-lightbox__counter"></p>
  </div>
</dialog>

<script>
  document.addEventListener('astro:page-load', () => {
    const dialog = document.getElementById('media-lightbox') as HTMLDialogElement | null;
    if (!dialog) return;

    const img = dialog.querySelector('.media-lightbox__img') as HTMLImageElement;
    const caption = dialog.querySelector('.media-lightbox__caption') as HTMLElement;
    const counter = dialog.querySelector('.media-lightbox__counter') as HTMLElement;
    const closeBtn = dialog.querySelector('.media-lightbox__close') as HTMLElement;
    const prevBtn = dialog.querySelector('.media-lightbox__nav--prev') as HTMLElement;
    const nextBtn = dialog.querySelector('.media-lightbox__nav--next') as HTMLElement;
    const backdrop = dialog.querySelector('.media-lightbox__backdrop') as HTMLElement;

    type LightboxItem = { src?: string; alt?: string; caption?: string };
    let items: LightboxItem[] = [];
    let currentIndex = 0;

    function getItems(): LightboxItem[] {
      return (window as any).__galleryLightboxItems || [];
    }

    function show(index: number) {
      items = getItems();
      if (items.length === 0) return;
      currentIndex = Math.max(0, Math.min(index, items.length - 1));
      update();
      dialog!.showModal();
    }

    function update() {
      const item = items[currentIndex];
      if (!item) return;
      img.src = item.src || '';
      img.alt = item.alt || '';
      caption.textContent = item.caption || '';
      caption.style.display = item.caption ? '' : 'none';
      counter.textContent = items.length > 1 ? `${currentIndex + 1} / ${items.length}` : '';

      const showNav = items.length > 1;
      prevBtn.style.display = showNav ? '' : 'none';
      nextBtn.style.display = showNav ? '' : 'none';
    }

    function navigate(delta: number) {
      currentIndex = (currentIndex + delta + items.length) % items.length;
      update();
    }

    function close() {
      dialog!.close();
    }

    document.querySelectorAll('.media-trigger[data-lightbox-index]').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.getAttribute('data-lightbox-index') || '0', 10);
        show(idx);
      });
    });

    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    prevBtn.addEventListener('click', () => navigate(-1));
    nextBtn.addEventListener('click', () => navigate(1));

    dialog.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft') navigate(-1);
      else if (e.key === 'ArrowRight') navigate(1);
      else if (e.key === 'Escape') close();
    });
  });
</script>
