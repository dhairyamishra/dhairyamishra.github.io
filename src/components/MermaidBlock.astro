---
interface Props {
  code: string;
}

const { code } = Astro.props;
---

<div class="mermaid-container rounded-lg border border-black/5 bg-surface p-4 overflow-x-auto">
  <pre class="mermaid">{code}</pre>
</div>

<script>
  async function initMermaid() {
    const { default: mermaid } = await import('mermaid');
    mermaid.initialize({
      startOnLoad: false,
      theme: 'base',
      themeVariables: {
        primaryColor: '#A63A3D',
        primaryTextColor: '#241A14',
        primaryBorderColor: '#7F2F33',
        lineColor: '#7F2F33',
        secondaryColor: '#F8F1E7',
        tertiaryColor: '#FFFFFF',
        background: '#FFFFFF',
        mainBkg: '#FFFFFF',
        nodeBorder: '#A63A3D',
        clusterBkg: '#F8F1E7',
        clusterBorder: '#B8891E',
        titleColor: '#241A14',
        edgeLabelBackground: '#FFFFFF',
        actorTextColor: '#241A14',
        actorBorder: '#A63A3D',
        signalColor: '#241A14',
        fontFamily: 'Inter, sans-serif',
      },
      securityLevel: 'loose',
    });
    await mermaid.run({ querySelector: '.mermaid' });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMermaid);
  } else {
    initMermaid();
  }

  document.addEventListener('astro:page-load', initMermaid);
</script>
