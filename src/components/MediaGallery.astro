---
import MermaidBlock from './MermaidBlock.astro';

interface MediaItem {
  type: 'image' | 'video' | 'diagram' | 'mermaid';
  src?: string;
  code?: string;
  alt?: string;
  caption?: string;
}

interface Props {
  media: MediaItem[];
}

const { media } = Astro.props;

if (!media || media.length === 0) return;

const lightboxItems = media.filter(m => m.type === 'image' || m.type === 'diagram');

function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|shorts\/))([^?&\s]+)/);
  return match ? match[1] : null;
}

function getVimeoId(url: string): string | null {
  const match = url.match(/vimeo\.com\/(\d+)/);
  return match ? match[1] : null;
}
---

<section class="mb-12" aria-label="Media gallery">
  <h2 class="text-xl font-heading font-bold text-text-bright mb-6 flex items-center gap-2">
    <svg class="w-5 h-5 text-neon-rose" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" /></svg>
    Gallery
  </h2>

  <div class="relative group">
    <!-- Left Navigation Button -->
    <button
      type="button"
      class="media-scroll-left absolute left-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity border border-white/10 hover:bg-neon-rose/80 backdrop-blur-sm shadow-xl focus:outline-none focus:ring-2 focus:ring-neon-rose hidden md:flex disabled:opacity-0 disabled:pointer-events-none"
      aria-label="Scroll left"
    >
      <svg class="w-5 h-5 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
    </button>

    <!-- Carousel Container -->
    <div class="media-carousel flex overflow-x-auto gap-4 snap-x snap-mandatory pb-4 mb-4 scrollbar-hide -mx-4 px-4 md:mx-0 md:px-0">
      {media.map((item, index) => {
      if (item.type === 'image' || item.type === 'diagram') {
        const lightboxIndex = lightboxItems.indexOf(item);
        return (
          <figure class="flex-none w-72 md:w-96 snap-start group">
            <button
              type="button"
              class="media-trigger w-full text-left"
              data-lightbox-index={lightboxIndex}
              aria-label={`View ${item.alt || 'media'} full size`}
            >
              <div class="relative overflow-hidden rounded-lg border border-white/5 group-hover:border-neon-rose/30 transition-all duration-300">
                <img
                  src={item.src}
                  alt={item.alt || ''}
                  class="w-full h-48 md:h-56 object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
                  <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-80 transition-opacity duration-300 drop-shadow-lg" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" /></svg>
                </div>
              </div>
            </button>
            {item.caption && (
              <figcaption class="text-xs text-muted mt-2 px-1 line-clamp-2">{item.caption}</figcaption>
            )}
          </figure>
        );
      }

      if (item.type === 'video' && item.src) {
        const ytId = getYouTubeId(item.src);
        const vimeoId = getVimeoId(item.src);
        return (
          <figure class="flex-none w-[85vw] md:w-[32rem] lg:w-[40rem] snap-start">
            <div class="relative overflow-hidden rounded-lg border border-white/5 aspect-video">
              {ytId ? (
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${ytId}`}
                  title={item.alt || 'Project video'}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="absolute inset-0 w-full h-full"
                  loading="lazy"
                />
              ) : vimeoId ? (
                <iframe
                  src={`https://player.vimeo.com/video/${vimeoId}?dnt=1`}
                  title={item.alt || 'Project video'}
                  allow="autoplay; fullscreen; picture-in-picture"
                  allowfullscreen
                  class="absolute inset-0 w-full h-full"
                  loading="lazy"
                />
              ) : (
                <p class="text-muted text-sm p-4">Unsupported video URL</p>
              )}
            </div>
            {item.caption && (
              <figcaption class="text-xs text-muted mt-2 px-1 line-clamp-2">{item.caption}</figcaption>
            )}
          </figure>
        );
      }

      if (item.type === 'mermaid' && item.code) {
        return (
          <figure class="flex-none w-[85vw] md:w-[32rem] snap-start">
            <MermaidBlock code={item.code} />
            {item.caption && (
              <figcaption class="text-xs text-muted mt-2 px-1 line-clamp-2">{item.caption}</figcaption>
            )}
          </figure>
        );
      }

      return null;
    })}
    </div>

    <!-- Right Navigation Button -->
    <button
      type="button"
      class="media-scroll-right absolute right-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity border border-white/10 hover:bg-neon-rose/80 backdrop-blur-sm shadow-xl focus:outline-none focus:ring-2 focus:ring-neon-rose hidden md:flex disabled:opacity-0 disabled:pointer-events-none"
      aria-label="Scroll right"
    >
      <svg class="w-5 h-5 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
    </button>
  </div>
</section>

<script define:vars={{ lightboxItems: JSON.stringify(lightboxItems) }}>
  window.__galleryLightboxItems = JSON.parse(lightboxItems);
</script>

<script>
  function setupCarousels() {
    const carousels = document.querySelectorAll('.media-carousel');
    
    carousels.forEach(container => {
      // Prevent multiple attaches
      if (container.hasAttribute('data-carousel-init')) return;
      container.setAttribute('data-carousel-init', 'true');

      const wrapper = container.closest('.relative.group');
      if (!wrapper) return;
      
      const leftBtn = wrapper.querySelector('.media-scroll-left');
      const rightBtn = wrapper.querySelector('.media-scroll-right');
      if (!leftBtn || !rightBtn) return;
      
      // Amount to scroll per click - roughly one standard item width + gap
      const scrollAmount = window.innerWidth < 768 ? 288 : 400; // 72rem or 96rem equivalent
      
      leftBtn.addEventListener('click', () => {
        container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });
      
      rightBtn.addEventListener('click', () => {
        container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
      
      const updateButtons = () => {
        const { scrollLeft, scrollWidth, clientWidth } = container;
        if (scrollLeft <= 5) {
          leftBtn.setAttribute('disabled', 'true');
        } else {
          leftBtn.removeAttribute('disabled');
        }
        
        if (Math.ceil(scrollLeft + clientWidth) >= scrollWidth - 5) {
          rightBtn.setAttribute('disabled', 'true');
        } else {
          rightBtn.removeAttribute('disabled');
        }
      };
      
      container.addEventListener('scroll', updateButtons, { passive: true });
      window.addEventListener('resize', updateButtons, { passive: true });
      
      // Delay initial check slightly to let images render and calculate width
      setTimeout(updateButtons, 150);
    });
  }

  // Handle standard load and Astro view transitions
  setupCarousels();
  document.addEventListener('astro:page-load', setupCarousels);
</script>
