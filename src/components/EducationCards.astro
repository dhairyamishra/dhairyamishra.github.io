---
import { Icon } from 'astro-icon/components';
import VerifiedBrandBadge from './VerifiedBrandBadge.astro';
import { education } from '../data/education';

interface Props {
  /** Compact homepage variant: smaller logo, no GPA star icon. */
  compact?: boolean;
}

const { compact = false } = Astro.props;

---

<div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
  {education.map((edu, i) => (
    <div class={`reveal reveal-delay-${i + 1} card-neon group`}>
      <div class="flex flex-col items-start gap-4 sm:flex-row">
        <VerifiedBrandBadge brand={edu.brand} size={compact ? 'sm' : 'md'} />
        <div>
          <h3 class={`font-heading font-semibold text-text-bright ${compact ? '' : 'text-lg'}`}>{edu.institution}</h3>
          {edu.subtitle && (
            <p class={`text-sm ${compact ? 'text-neon-rose/70' : 'text-neon-rose/80 font-medium mb-1'}`}>{edu.subtitle}</p>
          )}
          <p class={`text-sm text-muted ${compact ? 'mt-1' : ''}`}>{edu.degree}</p>
          {compact ? (
            <div class="flex items-center gap-3 mt-2 text-xs text-muted">
              <span>{edu.date}</span>
              {edu.gpa && <span class="text-neon-rose">GPA: {edu.gpa}</span>}
              {edu.location && <span>{edu.location}</span>}
            </div>
          ) : (
            <div class="flex items-center gap-3 mt-3 text-xs text-muted font-mono">
              <span class="bg-base px-2 py-0.5 rounded border border-black/5">{edu.date}</span>
              {edu.gpa && (
                <span class="text-neon-rose bg-neon-rose/10 px-2 py-0.5 rounded border border-neon-rose/10 flex items-center gap-1">
                  <Icon name="heroicons:star-20-solid" class="w-3 h-3" aria-hidden="true" />
                  {edu.gpa}
                </span>
              )}
              {edu.location && <span>{edu.location}</span>}
            </div>
          )}
        </div>
      </div>
    </div>
  ))}
</div>
